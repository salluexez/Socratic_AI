{
  "name": "socratic-ai",
  "private": true,
  "packageManager": "bun@1.3.11",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev": "turbo run dev",
    "dev:backend": "turbo run dev --filter=@socratic-ai/backend",
    "dev:web": "turbo run dev --filter=@socratic-ai/web",
    "build-and-run": "bun run scripts/build-and-run.mjs",
    "build": "turbo run build",
    "lint": "turbo run lint",
    "type-check": "turbo run type-check"
  },
  "devDependencies": {
    "turbo": "^2.0.0"
  }
}
